---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  currentPath?: string;
  image?: string;
}

const { title, description, currentPath, image = '/og-image.png' } = Astro.props;

const path = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : Astro.url.pathname + '/';
const canonicalUrl = new URL(path, Astro.site ?? 'https://havennotes.app').toString();
const imageUrl = new URL(image, Astro.site ?? 'https://havennotes.app').toString();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Haven Notes',
  operatingSystem: 'iOS, iPadOS',
  applicationCategory: 'ProductivityApplication',
  url: 'https://havennotes.app/',
  downloadUrl: 'https://apps.apple.com/app/id6744229406',
  description:
    'Private markdown notes for iOS with wiki links, knowledge graph, and end-to-end encryption.',
  offers: [
    { '@type': 'Offer', price: '0',     priceCurrency: 'USD', name: 'Free' },
    { '@type': 'Offer', price: '2.99',  priceCurrency: 'USD', name: 'Pro Monthly' },
    { '@type': 'Offer', price: '19.99', priceCurrency: 'USD', name: 'Pro Yearly' },
  ],
};
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#161512" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Haven Notes" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Haven Notes — A quiet place to think." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <noscript>
      <style>.reveal { opacity: 1 !important; transform: none !important; }</style>
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <script src="/scripts/site.js" defer is:inline></script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:px-4 focus:py-2 focus:bg-accent focus:text-bg focus:font-semibold focus:rounded-md"
    >
      Skip to content
    </a>
    <Nav currentPath={currentPath} />
    <main id="main" tabindex="-1" class="focus:outline-none">
      <slot />
    </main>
    <Footer />
  </body>
</html>
