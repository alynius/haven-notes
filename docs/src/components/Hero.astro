---
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';

const appStoreUrl = 'https://apps.apple.com/app/id6744229406';
---
<section class="relative overflow-hidden pt-20 pb-20 md:pt-28 md:pb-24 bg-glow-top">
  <div class="relative z-10 max-w-[720px] mx-auto px-6 text-center">
    <div class="reveal">
      <Eyebrow>Haven — Private notes for iOS</Eyebrow>
    </div>

    <h1 class="font-serif text-hero text-text-primary mt-2 reveal reveal-delay-1">
      A quiet place to think. No AI watching. No metrics counting.
    </h1>

    <p class="font-serif text-hero accent-italic mt-4 reveal reveal-delay-2">
      Just you and your words — the way writing used to feel.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mt-10 md:mt-12 reveal reveal-delay-3">
      <Button href={appStoreUrl} variant="primary" external={true}>Download for iOS</Button>
      <Button href="/story/" variant="outline">Read the story</Button>
    </div>
  </div>
</section>
