---
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';

const appStoreUrl = 'https://apps.apple.com/app/id6744229406';
---
<section class="relative overflow-hidden pt-20 pb-16 md:pt-28 md:pb-20 bg-glow-top">
  <div class="relative z-10 max-w-[640px] mx-auto px-6 text-center">
    <div class="reveal">
      <Eyebrow>Haven — Private notes for iOS</Eyebrow>
    </div>

    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-bold text-text-primary leading-[1.1] tracking-[-0.025em] mt-2 reveal reveal-delay-1">
      A quiet place to think.
    </h1>

    <p class="font-sans text-lg text-text-secondary mt-6 max-w-md mx-auto leading-relaxed reveal reveal-delay-2">
      Markdown notes with wiki links and a knowledge graph. No AI. No tracking. Private by design.
    </p>

    <p class="font-serif text-2xl md:text-3xl accent-italic leading-snug mt-10 reveal reveal-delay-2">
      Just you and your words — the way writing used to feel.
    </p>

    <div class="flex flex-wrap justify-center gap-3 mt-10 reveal reveal-delay-3">
      <Button href={appStoreUrl} variant="primary" external={true}>Download for iOS</Button>
      <Button href="/story/" variant="outline">Read the story</Button>
    </div>
  </div>
</section>
